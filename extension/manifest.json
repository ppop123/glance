{
  "manifest_version": 3,
  "name": "翻译 — 本地网页翻译器",
  "version": "0.1.0",
  "description": "基于本地 auth2api + 缓存的双语网页翻译。针对 x.com、github 做了适配优化，支持视频字幕生成。",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": { "service_worker": "src/background.js", "type": "module" },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": { "16": "assets/icon-16.png", "48": "assets/icon-48.png", "128": "assets/icon-128.png" }
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "icons": { "16": "assets/icon-16.png", "48": "assets/icon-48.png", "128": "assets/icon-128.png" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content_guard.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content_main.js",
        "src/subtitle.js",
        "src/site-adapters/xcom.js",
        "src/site-adapters/github.js",
        "src/site-adapters/generic.js",
        "src/lib/client.js",
        "src/lib/walker.js",
        "styles/inject.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-translate": {
      "suggested_key": { "default": "Alt+A", "mac": "Alt+A" },
      "description": "翻译/取消翻译当前页面"
    }
  }
}
